<!DOCTYPE html>
<html lang="en" class="bg-zinc-950 text-zinc-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ["Inter", "sans-serif"] },
            colors: {
              brand: {
                DEFAULT: "#38003c",
                light: "#e90052",
                accent: "#00ff87",
              },
            },
          },
        },
      };
    </script>
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body class="font-sans min-h-screen flex flex-col">
    <header class="bg-brand border-b border-brand-light/30 sticky top-0 z-50">
      <nav
        class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-2 text-white font-bold text-lg tracking-tight hover:text-brand-accent transition-colors"
        >
          <span class="text-brand-accent text-2xl">⚽</span>
          EPL Hub
        </a>
        <a
          href="/"
          class="text-zinc-300 hover:text-white text-sm transition-colors"
          >All Teams</a
        >
      </nav>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 py-10">
  </body>
</html>
