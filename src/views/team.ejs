<%- include('partials/header') %>

<!-- ── Team Hero (SSR) ──────────────────────────────────────────────────── -->
<div class="relative rounded-2xl overflow-hidden mb-10">
  <% if (team.strFanart1) { %>
  <img
    src="<%= team.strFanart1 %>/medium"
    alt="<%= team.strTeam %> fanart"
    class="w-full h-52 object-cover object-top"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/60 to-transparent"></div>
  <% } %>

  <div class="<%= team.strFanart1 ? 'absolute bottom-0 left-0 right-0' : '' %> p-6 flex items-end gap-6">
    <% if (team.strBadge) { %>
    <img src="<%= team.strBadge %>/small" alt="<%= team.strTeam %> badge" class="w-20 h-20 object-contain drop-shadow-xl" />
    <% } %>
    <div>
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest"><%= team.strLeague %></p>
      <h1 class="text-4xl font-bold text-white mt-0.5"><%= team.strTeam %></h1>
      <p class="text-zinc-400 text-sm mt-1">
        Founded <%= team.intFormedYear || '—' %> &nbsp;&middot;&nbsp; <%= team.strStadium || '—' %>
        <% if (team.intStadiumCapacity) { %>&nbsp;(<%= Number(team.intStadiumCapacity).toLocaleString() %> cap)<% } %>
      </p>
    </div>
  </div>
</div>

<!-- ── Info + Description (SSR) ─────────────────────────────────────────── -->
<div class="grid lg:grid-cols-3 gap-8 mb-12">
  <!-- About -->
  <div class="lg:col-span-2 space-y-4">
    <h2 class="text-lg font-semibold text-white border-b border-zinc-800 pb-2">About</h2>
    <% const desc = team.strDescriptionEN || '' %>
    <% if (desc) { %>
    <div id="description-wrap" class="relative">
      <p id="description-text" class="text-zinc-400 text-sm leading-relaxed line-clamp-6">
        <%= desc %>
      </p>
      <% if (desc.length > 400) { %>
      <button
        onclick="toggleDesc()"
        id="desc-btn"
        class="mt-2 text-brand-accent text-sm hover:underline"
      >Read more</button>
      <% } %>
    </div>
    <% } else { %>
    <p class="text-zinc-500 text-sm italic">No description available.</p>
    <% } %>
  </div>

  <!-- Quick facts -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 space-y-3 self-start">
    <h2 class="text-lg font-semibold text-white border-b border-zinc-800 pb-2">Quick Facts</h2>
    <% const facts = [
      ['Country',  team.strCountry],
      ['City',     team.strLocation],
      ['Manager',  team.strManager],
      ['Website',  team.strWebsite],
      ['Social',   team.strTwitter ? '@' + team.strTwitter : null],
      ['Kit',      team.strKit],
    ] %>
    <% facts.forEach(([label, val]) => { %>
    <% if (val) { %>
    <div class="flex justify-between gap-2 text-sm">
      <span class="text-zinc-500"><%= label %></span>
      <% if (label === 'Website') { %>
      <a href="https://<%= val %>" target="_blank" rel="noopener"
         class="text-brand-accent hover:underline truncate max-w-[60%]"><%= val %></a>
      <% } else { %>
      <span class="text-zinc-200 text-right"><%= val %></span>
      <% } %>
    </div>
    <% } %>
    <% }) %>
  </div>
</div>

<!-- ── Dynamic Events Section (Vue) ────────────────────────────────────── -->
<div id="events-app" class="mb-12">
  <events-section team-id="<%= team.idTeam %>"></events-section>
</div>

<!-- ── Squad (SSR) ──────────────────────────────────────────────────────── -->
<div>
  <h2 class="text-xl font-semibold text-white mb-6 border-b border-zinc-800 pb-2">
    Squad
    <span class="text-zinc-500 text-base font-normal ml-2">(<%= players.length %> players)</span>
  </h2>

  <% if (players.length === 0) { %>
  <p class="text-zinc-500 italic text-sm">No squad data available.</p>
  <% } else { %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-4">
    <% players.forEach(player => { %>
    <a href="/player/<%= player.idPlayer %>?data=<%= encodeURIComponent(JSON.stringify(player)) %>"
       class="group bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-brand-accent/50 hover:bg-zinc-800 transition-all">
      <div class="aspect-square overflow-hidden bg-zinc-800">
        <% if (player.strThumb) { %>
        <img
          src="<%= player.strThumb %>/small"
          alt="<%= player.strPlayer %>"
          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
        <% } else { %>
        <div class="w-full h-full flex items-center justify-center text-4xl text-zinc-600">👤</div>
        <% } %>
      </div>
      <div class="p-3">
        <p class="text-sm font-medium text-zinc-200 group-hover:text-white leading-tight line-clamp-2">
          <%= player.strPlayer %>
        </p>
        <p class="text-xs text-zinc-500 mt-0.5"><%= player.strPosition || '—' %></p>
      </div>
    </a>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- ── Vue Events Component ─────────────────────────────────────────────── -->
<script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
<script src="/js/events.js"></script>

<script>
function toggleDesc() {
  const text = document.getElementById('description-text')
  const btn  = document.getElementById('desc-btn')
  const expanded = text.classList.toggle('line-clamp-6')
  btn.textContent = expanded ? 'Read more' : 'Show less'
}
</script>

<%- include('partials/footer') %>
