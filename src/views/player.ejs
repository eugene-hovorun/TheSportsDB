<%- include('partials/header') %>

<div class="mb-6">
  <a href="javascript:history.back()" class="text-brand-accent hover:underline text-sm">&larr; Back</a>
</div>

<!-- ── Player Hero (SSR) ──────────────────────────────────────────────── -->
<div class="flex flex-col sm:flex-row gap-8 mb-10">
  <!-- Photo -->
  <div class="flex-shrink-0">
    <% if (player.strThumb) { %>
    <img
      src="<%= player.strThumb %>/medium"
      alt="<%= player.strPlayer %>"
      class="w-48 h-48 rounded-2xl object-cover object-top bg-zinc-800 shadow-xl"
    />
    <% } else { %>
    <div class="w-48 h-48 rounded-2xl bg-zinc-800 flex items-center justify-center text-6xl shadow-xl">👤</div>
    <% } %>
  </div>

  <!-- Name + Meta -->
  <div class="flex flex-col justify-center gap-3">
    <div>
      <% if (player.strNationality) { %>
      <p class="text-brand-accent text-sm font-semibold uppercase tracking-widest mb-1"><%= player.strNationality %></p>
      <% } %>
      <h1 class="text-4xl font-bold text-white"><%= player.strPlayer %></h1>
      <p class="text-zinc-400 mt-1 text-base">
        <%= player.strPosition || 'Unknown position' %>
        <% if (player.strTeam) { %>
        &nbsp;&middot;&nbsp;
        <% if (player.idTeam) { %>
        <a href="/team/<%= player.idTeam %>" class="text-brand-accent hover:underline"><%= player.strTeam %></a>
        <% } else { %><%= player.strTeam %><% } %>
        <% } %>
      </p>
    </div>

    <!-- Stat chips -->
    <div class="flex flex-wrap gap-2">
      <% const chips = [
        ['Shirt #', player.strNumber],
        ['Height',  player.strHeight],
        ['Weight',  player.strWeight],
        ['Born',    player.dateBorn ? player.dateBorn.slice(0,10) : null],
        ['Birthplace', player.strBirthLocation],
      ] %>
      <% chips.forEach(([label, val]) => { %>
      <% if (val) { %>
      <span class="bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-1 text-sm">
        <span class="text-zinc-500"><%= label %>:</span>
        <span class="text-zinc-200 ml-1"><%= val %></span>
      </span>
      <% } %>
      <% }) %>
    </div>
  </div>

  <!-- Cutout if available (decorative) -->
  <% if (player.strCutout) { %>
  <div class="hidden xl:block ml-auto flex-shrink-0">
    <img src="<%= player.strCutout %>/medium" alt="" class="h-48 object-contain" />
  </div>
  <% } %>
</div>

<!-- ── Bio + Stats grid (SSR) ─────────────────────────────────────────── -->
<div class="grid lg:grid-cols-3 gap-8 mb-10">
  <!-- Biography -->
  <div class="lg:col-span-2">
    <h2 class="text-lg font-semibold text-white border-b border-zinc-800 pb-2 mb-4">Biography</h2>
    <% const bio = player.strDescriptionEN || '' %>
    <% if (bio) { %>
    <p class="text-zinc-400 text-sm leading-relaxed"><%= bio %></p>
    <% } else { %>
    <p class="text-zinc-500 text-sm italic">No biography available.</p>
    <% } %>
  </div>

  <!-- Career facts sidebar -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 space-y-3 self-start">
    <h2 class="text-lg font-semibold text-white border-b border-zinc-800 pb-2">Career</h2>
    <% const careerFacts = [
      ['Signing',  player.strSigning],
      ['Wage',     player.strWage],
      ['Agent',    player.strAgent],
      ['Instagram', player.strInstagram ? '@' + player.strInstagram : null],
      ['Twitter',  player.strTwitter ? '@' + player.strTwitter : null],
    ] %>
    <% careerFacts.forEach(([label, val]) => { %>
    <% if (val) { %>
    <div class="flex justify-between gap-2 text-sm">
      <span class="text-zinc-500"><%= label %></span>
      <span class="text-zinc-200 text-right"><%= val %></span>
    </div>
    <% } %>
    <% }) %>
  </div>
</div>

<!-- ── Fan art banner ─────────────────────────────────────────────────── -->
<% if (player.strFanart1) { %>
<div class="rounded-xl overflow-hidden mt-4">
  <img src="<%= player.strFanart1 %>/medium" alt="" class="w-full h-40 object-cover object-center opacity-60" />
</div>
<% } %>

<%- include('partials/footer') %>
