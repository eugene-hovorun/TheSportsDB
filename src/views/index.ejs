<%- include('partials/header') %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-white">Premier League Teams</h1>
  <p class="text-zinc-400 mt-1">2024/25 season &mdash; select a club to explore the squad</p>
</div>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
  <% teams.forEach(team => { %>
  <a href="/team/<%= team.idTeam %>" class="group bg-zinc-900 border border-zinc-800 rounded-xl p-4 flex flex-col items-center gap-3 hover:border-brand-accent/60 hover:bg-zinc-800 transition-all duration-200">

    <% const badgeTiny = imgUrl(team.strBadge, 'tiny') %>
    <% if (badgeTiny) { %>
    <img src="<%= badgeTiny %>" alt="<%= team.strTeam %> badge" class="w-14 h-14 object-contain group-hover:scale-110 transition-transform duration-200" loading="lazy" />
    <% } else { %>
    <div class="w-14 h-14 rounded-full bg-zinc-700 flex items-center justify-center text-2xl">⚽
    </div>
    <% } %>

    <span class="text-sm font-medium text-zinc-200 text-center leading-tight group-hover:text-white">
      <%= team.strTeam %>
    </span>

    <% if (team.strStadium) { %>
    <span class="text-xs text-zinc-500 text-center truncate w-full"><%= team.strStadium %></span>
    <% } %>
  </a>
  <% }) %>
</div>

<%- include('partials/footer') %>