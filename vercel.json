{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/views/**", "src/public/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/dist/server.js" }]
}
